                  "pm.test('T09 - error DADOS_INVALIDOS', () => {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j.error).to.eql('DADOS_INVALIDOS');",
                  "  const campos = j.details.map(d => d.field);",
                  "  pm.expect(campos).to.include('canal_pedido');",
                  "});"
