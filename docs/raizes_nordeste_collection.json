  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "T01 - Login válido ADMIN",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('T01 - Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('T01 - Retorna accessToken', () => {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j).to.have.property('accessToken');",
                  "  pm.expect(j.usuario.perfil).to.eql('ADMIN');",
                  "  pm.collectionVariables.set('token_admin', j.accessToken);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"admin@raizes.com\", \"senha\": \"Admin@2026\"}"
            }
          }
        },
        {
          "name": "T02 - Login válido CLIENTE",
