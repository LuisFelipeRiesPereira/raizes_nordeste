    {
      "name": "Pedidos",
      "item": [
        {
          "name": "T07 - Criar pedido válido via APP (valor ≤ R$200 → APROVADO)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('T07 - Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('T07 - canal_pedido APP', () => pm.expect(pm.response.json().canal_pedido).to.eql('APP'));",
                  "pm.test('T07 - status AGUARDANDO_PAGAMENTO', () => pm.expect(pm.response.json().status).to.eql('AGUARDANDO_PAGAMENTO'));",
                  "pm.test('T07 - valor_total calculado', () => pm.expect(pm.response.json().valor_total).to.be.a('number'));",
                  "pm.collectionVariables.set('pedido_id_aprovado', pm.response.json().id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token_cliente}}"
              }
            ],
            "url": "{{base_url}}/pedidos",
            "body": {
              "mode": "raw",
              "raw": "{\"unidade_id\": 1, \"canal_pedido\": \"APP\", \"itens\": [{\"produto_id\": 1, \"quantidade\": 2}], \"observacao\": \"Sem pimenta\"}"
            }
          }
        },
        {
