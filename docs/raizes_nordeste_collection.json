    },
    {
      "name": "Cardapio por Unidade",
      "item": [
        {
          "name": "T17 - Cardapio filtrado por unidade (com estoque)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('T17 - Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('T17 - Inclui unidade_id na resposta', () => {",
                  "  pm.expect(pm.response.json().unidade_id).to.eql(1);",
                  "});",
                  "pm.test('T17 - Cada produto tem estoque_disponivel > 0', () => {",
                  "  const data = pm.response.json().data;",
                  "  data.forEach(p => {",
                  "    pm.expect(p).to.have.property('estoque_disponivel');",
                  "    pm.expect(p.estoque_disponivel).to.be.greaterThan(0);",
                  "  });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/produtos?unidade_id=1&page=1&limit=20"
          }
        }
      ]
    },
    {
      "name": "Cancelamento",
      "item": [
        {
          "name": "T18 - Cancelar pedido com motivo (operacao sensivel)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// cria um pedido novo antes pra ter o que cancelar",
                  "const token = pm.collectionVariables.get('token_cliente');",
                  "pm.sendRequest({",
                  "  url: pm.collectionVariables.get('base_url') + '/pedidos',",
                  "  method: 'POST',",
                  "  header: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },",
                  "  body: { mode: 'raw', raw: JSON.stringify({",
                  "    unidade_id: 1, canal_pedido: 'APP',",
                  "    itens: [{produto_id: 3, quantidade: 1}]",
                  "  })}",
                  "}, (err, res) => {",
                  "  if (res && res.json() && res.json().id) {",
                  "    pm.collectionVariables.set('pedido_id_cancelar', res.json().id);",
                  "  }",
                  "});"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('T18 - Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('T18 - mensagem de sucesso', () => {",
                  "  pm.expect(pm.response.json().mensagem).to.include('cancelado');",
                  "});",
                  "pm.test('T18 - estoque foi devolvido', () => {",
                  "  pm.expect(pm.response.json().estoque_devolvido).to.eql(true);",
                  "});",
                  "pm.test('T18 - pedido em status CANCELADO', () => {",
                  "  pm.expect(pm.response.json().pedido.status).to.eql('CANCELADO');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token_cliente}}"
              }
            ],
            "url": "{{base_url}}/pedidos/{{pedido_id_cancelar}}/cancelar",
            "body": {
              "mode": "raw",
              "raw": "{\"motivo\": \"Cliente desistiu antes do preparo\"}"
            }
          }
        }
      ]
    },
