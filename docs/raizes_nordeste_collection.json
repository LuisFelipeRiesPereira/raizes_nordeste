            ],
            "url": "{{base_url}}/pedidos",
            "body": {
              "mode": "raw",
              "raw": "{\"unidade_id\": 1, \"itens\": [{\"produto_id\": 1, \"quantidade\": 1}]}"
            }
          }
        },
