          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('T19 - Status 409', () => pm.response.to.have.status(409));",
                  "pm.test('T19 - error ESTOQUE_INSUFICIENTE', () => {",
                  "  pm.expect(pm.response.json().error).to.eql('ESTOQUE_INSUFICIENTE');",
