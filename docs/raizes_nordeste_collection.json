                  "  pm.expect(j.usuario.perfil).to.eql('CLIENTE');",
                  "  pm.collectionVariables.set('token_cliente', j.accessToken);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
