            "body": {
              "mode": "raw",
              "raw": "{\"unidade_id\": 1, \"canal_pedido\": \"TOTEM\", \"itens\": [{\"produto_id\": 2, \"quantidade\": 5}], \"observacao\": \"Pedido alto valor para teste de recusa\"}"
