#----
# variaveis de ambiente do projeto
# renomeie o arquivo para .env para iniciar o projeto
#----

# conexao com o banco postgresql

# formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
#
# crie tudo igual ao readme

DATABASE_URL=postgresql://raizes_user:raizes_pass@localhost:5432/raizes_nordeste

# chave secreta pra assinar os tokens jwt

# o JWT usa essa chave pra garantir que o token nao foi adulterado
# para utilizar na produção
# se mudar essa chave todos os tokens ja gerados ficam invalidos
SECRET_KEY=raizes-nordeste-secret-2026

# tempo de validade do token jwt em minutos

# depois desse tempo o usuario precisa fazer login de novo
# 60 minutos

ACCESS_TOKEN_EXPIRE_MINUTES=60